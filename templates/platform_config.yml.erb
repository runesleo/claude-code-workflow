# <%= platform_name %> Platform Configuration
# Generated by claude-code-workflow configuration generator
# Template Version: 1.0.0

<%# 
  This template generates platform configuration for config/platforms.yaml
  
  Required variables:
    - platform_id: Unique identifier (e.g., "cursor", "vscode")
    - platform_name: Display name (e.g., "Cursor IDE", "VS Code")
    - description: Platform description
  
  Optional variables:
    - doc_types: Array of document types (default: basic set)
    - runtime_dirs: Array of runtime directories (default: [])
    - copy_mode: "full", "minimal", or "none" (default: "minimal")
    - has_native_config: Boolean (default: false)
    - native_config_filename: Native config filename (default: nil)
    - special_handling: Hash of special flags (default: {})
%>

<%# Set defaults %>
<% doc_types ||= %w[behavior safety task_routing test_standards] %>
<% runtime_dirs ||= [] %>
<% copy_mode ||= "minimal" %>
<% has_native_config ||= false %>
<% special_handling ||= {} %>

<%= platform_id %>:
  target_id: <%= platform_id %>
  display_name: <%= platform_name %>
  description: <%= description %>

  output_paths:
    global:
      vibe_subdir: .vibe/<%= platform_id %>
      entrypoint_name: <%= entrypoint_name || "AGENTS.md" %>
    project:
      vibe_subdir: .vibe/<%= platform_id %>
      entrypoint_name: <%= entrypoint_name || "AGENTS.md" %>

  doc_types:
    global: [<%= doc_types.join(', ') %>]
    project: [<%= doc_types.join(', ') %>]
<% if has_native_config %>

  native_config:
    global:
      type: json
      filename: <%= native_config_filename %>
      template: <%= platform_id %>/<%= native_config_filename %>.erb
    project:
      type: json
      filename: <%= native_config_filename %>
      template: <%= platform_id %>/<%= native_config_filename %>.erb
<% else %>

  native_config: {}
<% end %>

  runtime_dirs: [<%= runtime_dirs.map { |d| "'#{d}'" }.join(', ') %>]
  copy_mode: <%= copy_mode %>
<% unless special_handling.empty? %>

  special_handling:
<% special_handling.each do |key, value| %>
    <%= key %>: <%= value %>
<% end %>
<% end %>
