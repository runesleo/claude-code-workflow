#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "json"
require "optparse"
require "time"
require "digest"
require "yaml"
require_relative "../lib/vibe/errors"
require_relative "../lib/vibe/utils"
require_relative "../lib/vibe/doc_rendering"
require_relative "../lib/vibe/native_configs"
require_relative "../lib/vibe/overlay_support"
require_relative "../lib/vibe/path_safety"
require_relative "../lib/vibe/target_renderers"
require_relative "../lib/vibe/external_tools"
require_relative "../lib/vibe/init_support"

class VibeCLI
  include Vibe::Utils
  include Vibe::DocRendering
  include Vibe::NativeConfigs
  include Vibe::OverlaySupport
  include Vibe::PathSafety
  include Vibe::TargetRenderers
  include Vibe::ExternalTools
  include Vibe::InitSupport

  TARGET_ALIASES = {
    "claude" => "claude-code",
    "claude-code" => "claude-code",
    "codex" => "codex-cli",
    "codex-cli" => "codex-cli",
    "cursor" => "cursor",
    "opencode" => "opencode",
    "warp" => "warp",
    "vscode" => "vscode",
    "antigravity" => "antigravity",
    "kimi" => "kimi-code",
    "kimi-code" => "kimi-code"
  }.freeze

  SUPPORTED_TARGETS = %w[antigravity claude-code codex-cli cursor kimi-code opencode vscode warp].freeze
  MARKER_FILENAME = ".vibe-target.json"

  def initialize(repo_root)
    @repo_root = repo_root
    # YAML files are now loaded lazily on first access
  end

  # Lazy-loaded YAML documents with caching
  def tiers_doc
    @tiers_doc ||= read_yaml("core/models/tiers.yaml")
  end

  def providers
    @providers ||= read_yaml("core/models/providers.yaml")
  end

  def skills_doc
    @skills_doc ||= read_yaml("core/skills/registry.yaml")
  end

  def security_doc
    @security_doc ||= read_yaml("core/security/policy.yaml")
  end

  def policies_doc
    @policies_doc ||= read_yaml("core/policies/behaviors.yaml")
  end

  def task_routing_doc
    @task_routing_doc ||= read_yaml("core/policies/task-routing.yaml")
  end

  def test_standards_doc
    @test_standards_doc ||= read_yaml("core/policies/test-standards.yaml")
  end

  def run(argv)
    command = argv.shift

    case command
    when "build"
      run_build(argv)
    when "use"
      run_use(argv, switch_mode: false)
    when "switch"
      run_use(argv, switch_mode: true)
    when "inspect"
      run_inspect(argv)
    when "init"
      run_init_command(argv)
    when "targets"
      puts SUPPORTED_TARGETS.join("
")
    when "help", "--help", "-h", nil
      puts usage
    else
      raise Vibe::ValidationError, "Unknown command: #{command}

#{usage}"
    end
  end

  private

  def usage
    <<~TEXT
      Usage:
        bin/vibe build TARGET [--profile PROFILE] [--output DIR] [--overlay FILE]
        bin/vibe use TARGET DESTINATION [--profile PROFILE] [--output DIR] [--overlay FILE] [--force]
        bin/vibe switch TARGET [--profile PROFILE] [--output DIR] [--overlay FILE] [--force]
        bin/vibe inspect [TARGET] [--overlay FILE] [--json]
        bin/vibe init [--verify]
        bin/vibe targets

      Overlay discovery:
        - If --overlay FILE is provided, that file is used.
        - Otherwise `use` / `switch` look for `.vibe/overlay.yaml` in the destination root.
        - Other commands fall back to the workflow repo root.

      Notes:
        - TARGET may also be passed via --target TARGET.
        - DESTINATION may also be passed via --destination DIR.
        - switch defaults to the repository root for codex-cli/cursor/opencode/warp,
          and ~/.claude for claude-code.

      Supported targets:
        #{SUPPORTED_TARGETS.join(", ")}
    TEXT
  end

  def run_build(argv)
    options, remaining = parse_common_options(
      argv,
      banner: "Usage: bin/vibe build TARGET [--profile PROFILE] [--output DIR] [--overlay FILE]"
    )
    extract_target_from_remaining!(options, remaining)
    ensure_no_remaining_args!(remaining)

    target = require_target!(options)
    profile_name, profile = resolve_profile(target, options[:profile])
    output_root = File.expand_path(options[:output] || default_output_root(target))

    # Validate output path if explicitly provided
    validate_path!(options[:output], context: "output") if options[:output]

    overlay = resolve_overlay(explicit_path: options[:overlay], search_roots: [@repo_root])

    manifest = build_target(
      target: target,
      profile_name: profile_name,
      profile: profile,
      output_root: output_root,
      overlay: overlay
    )

    puts "Built #{target} (#{profile_name})#{overlay_label(manifest)} -> #{output_root}"
  end

  def run_use(argv, switch_mode:)
    banner = if switch_mode
      "Usage: bin/vibe switch TARGET [--profile PROFILE] [--output DIR] [--overlay FILE] [--force]"
    else
      "Usage: bin/vibe use TARGET DESTINATION [--profile PROFILE] [--output DIR] [--overlay FILE] [--force]"
    end

    options, remaining = parse_common_options(argv, banner: banner)
    extract_target_from_remaining!(options, remaining)
    extract_destination_from_remaining!(options, remaining) unless switch_mode
    ensure_no_remaining_args!(remaining)

    target = require_target!(options)
    options[:destination] ||= default_destination_for_target(target) if switch_mode
    destination = options[:destination]
    raise Vibe::ValidationError, "Missing required destination. Pass DESTINATION or --destination DIR." if destination.nil? || destination.strip.empty?

    # Validate destination path
    validate_path!(destination, context: "destination")

    profile_name, profile = resolve_profile(target, options[:profile])
    destination_root = File.expand_path(destination)
    output_root = resolve_output_root_for_use(
      target: target,
      destination_root: destination_root,
      explicit_output: options[:output]
    )
    ensure_no_path_overlap!(output_root, destination_root)
    overlay = resolve_overlay(explicit_path: options[:overlay], search_roots: [destination_root, @repo_root])

    manifest = build_target(
      target: target,
      profile_name: profile_name,
      profile: profile,
      output_root: output_root,
      overlay: overlay
    )
    enforce_safe_destination!(output_root, destination_root, options[:force])

    FileUtils.mkdir_p(destination_root)
    copy_tree_contents(output_root, destination_root)

    write_marker(
      File.join(destination_root, MARKER_FILENAME),
      destination_root: destination_root,
      manifest: manifest,
      output_root: output_root,
      mode: switch_mode ? "switch" : "use"
    )

    puts "Applied #{target} (#{profile_name})#{overlay_label(manifest)} -> #{destination_root}"
  end

  def run_inspect(argv)
    options = { json: false }
    parser = OptionParser.new do |opts|
      opts.banner = "Usage: bin/vibe inspect [TARGET] [--overlay FILE] [--json]"

      opts.on("--target TARGET", "Limit inspection to one target") do |value|
        options[:target] = normalize_target(value)
      end

      opts.on("--overlay FILE", "Apply a project overlay when previewing target resolution") do |value|
        options[:overlay] = value
      end

      opts.on("--json", "Output machine-readable JSON") do
        options[:json] = true
      end

      opts.on("-h", "--help", "Show help") do
        puts opts
        exit 0
      end
    end

    remaining = parser.parse(argv)
    if options[:target].nil? && !remaining.empty?
      options[:target] = normalize_target(remaining.shift)
    end
    ensure_no_remaining_args!(remaining)

    overlay = resolve_overlay(explicit_path: options[:overlay], search_roots: [@repo_root])
    payload = inspect_payload(target: options[:target], overlay: overlay)
    if options[:json]
      puts JSON.pretty_generate(payload)
    else
      puts render_inspect(payload)
    end
  end

  def run_init_command(argv)
    verify_only = false

    argv.each do |arg|
      case arg
      when "--verify"
        verify_only = true
      when "--help", "-h"
        puts <<~HELP
          Usage: bin/vibe init [--verify]

          Initialize external integrations for Claude Code Workflow.

          Options:
            --verify    Only verify existing integrations without installing

          Integrations:
            - Superpowers: Skill pack with advanced capabilities
            - RTK: Token optimizer reducing LLM costs by 60-90%
        HELP
        return
      else
        raise Vibe::ValidationError, "Unknown option: #{arg}\n\nRun 'bin/vibe init --help' for usage."
      end
    end

    run_init(verify_only: verify_only)
  end

  def parse_common_options(argv, banner:)
    options = { force: false }

    parser = OptionParser.new do |opts|
      opts.banner = banner

      opts.on("--target TARGET", "Target name (#{SUPPORTED_TARGETS.join(', ')})") do |value|
        options[:target] = normalize_target(value)
      end

      opts.on("--profile PROFILE", "Explicit profile name from core/models/providers.yaml") do |value|
        options[:profile] = value
      end

      opts.on("--output DIR", "Write generated files to DIR instead of generated/<target>") do |value|
        validate_path!(value, context: "output")
        options[:output] = value
      end

      opts.on("--destination DIR", "Destination root for `use`") do |value|
        validate_path!(value, context: "destination")
        options[:destination] = value
      end

      opts.on("--overlay FILE", "Apply a project overlay file while rendering") do |value|
        validate_path!(value, context: "overlay")
        options[:overlay] = value
      end

      opts.on("--force", "Allow overwriting existing generated target files at the destination") do
        options[:force] = true
      end

      opts.on("-h", "--help", "Show help") do
        puts opts
        exit 0
      end
    end

    remaining = parser.parse(argv)
    [options, remaining]
  end

  def extract_target_from_remaining!(options, remaining)
    return unless options[:target].nil?
    return if remaining.empty?

    candidate = remaining.first
    return if candidate.start_with?("-")

    options[:target] = normalize_target(remaining.shift)
  end

  def extract_destination_from_remaining!(options, remaining)
    return unless options[:destination].nil?
    return if remaining.empty?

    candidate = remaining.first
    return if candidate.start_with?("-")

    options[:destination] = remaining.shift
  end

  def ensure_no_remaining_args!(remaining)
    return if remaining.empty?

    raise Vibe::ValidationError, "Unexpected arguments: #{remaining.join(' ')}"
  end

  def require_target!(options)
    target = options[:target]
    raise Vibe::ValidationError, "Missing required target. Pass TARGET or --target TARGET." if target.nil?

    target
  end

  def normalize_target(value)
    normalized = TARGET_ALIASES[value]
    raise Vibe::ValidationError, "Unsupported target: #{value}" if normalized.nil? || !SUPPORTED_TARGETS.include?(normalized)

    normalized
  end

  def default_output_root(target)
    File.join(@repo_root, "generated", target)
  end

  def default_destination_for_target(target)
    if target == "claude-code"
      File.join(Dir.home, ".claude")
    else
      @repo_root
    end
  end

  def resolve_output_root_for_use(target:, destination_root:, explicit_output:)
    return File.expand_path(explicit_output) if explicit_output

    output_root = File.expand_path(default_output_root(target))
    return output_root unless paths_overlap?(output_root, destination_root)

    destination_name = File.basename(destination_root)
    destination_name = sanitize_directory_name(destination_name)
    destination_name = "root" if destination_name.empty?
    destination_digest = Digest::SHA256.hexdigest(destination_root)[0, 12]

    home_dir = Dir.home
    raise Vibe::ConfigurationError, "Cannot determine home directory for external staging" if home_dir.nil? || home_dir.empty?

    File.join(home_dir, ".vibe-generated", "#{destination_name}-#{destination_digest}", target)
  end

  def sanitize_directory_name(name)
    return "root" if name.nil? || name.empty? || name == File::SEPARATOR

    # Replace special characters with hyphens, preserve alphanumeric, underscore, and hyphen
    sanitized = name.gsub(/[^a-zA-Z0-9_-]/, "-")
    # Collapse consecutive hyphens
    sanitized = sanitized.gsub(/-+/, "-")
    # Remove leading/trailing hyphens (use gsub to handle both ends)
    sanitized = sanitized.gsub(/^-+|-+$/, "")

    # Return "root" if sanitization resulted in empty string
    sanitized.empty? ? "root" : sanitized
  end

  def resolve_profile(target, requested_profile)
    profiles = providers.fetch("profiles")

    if requested_profile
      profile = profiles[requested_profile]
      raise Vibe::ConfigurationError, "Unknown profile: #{requested_profile}" if profile.nil?
      raise Vibe::ValidationError, "Profile #{requested_profile} does not target #{target}" unless profile["target"] == target

      return [requested_profile, profile]
    end

    default_profile_for_target(target)
  end

  def default_profile_for_target(target)
    profiles = providers.fetch("profiles").select { |_name, profile| profile["target"] == target }
    raise Vibe::ConfigurationError, "No profile found for target #{target}" if profiles.empty?

    profiles.sort_by do |_name, profile|
      case profile["maturity"]
      when "active" then 0
      when "planned" then 1
      else 2
      end
    end.first
  end


  def build_target(target:, profile_name:, profile:, output_root:, overlay:)
    ensure_safe_output_path!(output_root)

    manifest = build_manifest(
      target: target,
      profile_name: profile_name,
      profile: profile,
      output_root: output_root,
      overlay: overlay
    )

    FileUtils.rm_rf(output_root)
    FileUtils.mkdir_p(output_root)

    case target
    when "claude-code"
      render_claude(output_root, manifest)
    when "codex-cli"
      render_codex(output_root, manifest)
    when "cursor"
      render_cursor(output_root, manifest)
    when "kimi-code"
      render_kimi_code(output_root, manifest)
    when "opencode"
      render_opencode(output_root, manifest)
    when "warp"
      render_warp(output_root, manifest)
    when "antigravity"
      render_antigravity(output_root, manifest)
    when "vscode"
      render_vscode(output_root, manifest)
    else
      raise Vibe::ConfigurationError, "Target renderer not implemented: #{target}"
    end

    vibe_dir = File.join(output_root, ".vibe")
    FileUtils.mkdir_p(vibe_dir)
    write_json(File.join(vibe_dir, "manifest.json"), manifest)
    File.write(File.join(vibe_dir, "target-summary.md"), render_target_summary(manifest))
    manifest
  end

  def build_manifest(target:, profile_name:, profile:, output_root:, overlay:)
    profile_mapping = deep_merge(profile.fetch("mapping"), overlay_profile_mapping_overrides(overlay))
    profile_notes = (Array(profile["notes"]) + overlay_profile_note_append(overlay)).uniq
    policies = effective_policies(overlay)
    native_config_overlay = overlay_target_patch(overlay, target)

    {
      "schema_version" => 5,
      "generated_at" => Time.now.utc.iso8601,
      "source_repo" => ".",
      "output_root" => display_path(File.expand_path(output_root)),
      "target" => target,
      "profile" => profile_name,
      "profile_maturity" => profile["maturity"],
      "profile_notes" => profile_notes,
      "profile_mapping" => profile_mapping,
      "overlay" => overlay_summary(overlay, target: target),
      "native_config_overlay" => native_config_overlay,
      "routing_defaults" => tiers_doc["routing_defaults"],
      "tiers" => tiers_doc.fetch("tiers").transform_values do |tier|
        {
          "description" => tier["description"],
          "default_role" => tier["default_role"],
          "route_when" => tier["route_when"] || [],
          "avoid_when" => tier["avoid_when"] || []
        }
      end,
      "skills" => manifest_skills(target),
      "policies" => policies,
      "security" => {
        "severity_levels" => security_doc.fetch("severity_levels"),
        "signal_categories" => security_doc.fetch("signal_categories"),
        "adjudication_factors" => security_doc.fetch("adjudication_factors"),
        "target_actions" => security_doc.fetch("actions_by_target")[target]
      }
    }
  end

  def manifest_skills(target)
    skills_doc.fetch("skills").select do |skill|
      include_skill_in_manifest?(skill)
    end.map do |skill|
      {
        "id" => skill["id"],
        "namespace" => skill["namespace"],
        "intent" => skill["intent"],
        "trigger_mode" => skill["trigger_mode"],
        "priority" => skill["priority"],
        "target_support" => skill.fetch("supported_targets", {})[target]
      }
    end
  end

  def include_skill_in_manifest?(skill)
    condition = skill["conditional"]
    return true if condition.nil? || condition.to_s.strip.empty?

    case condition
    when "superpowers_installed"
      detect_superpowers != :not_installed
    else
      false
    end
  end

  def inspect_payload(target:, overlay:)
    targets = target ? [target] : SUPPORTED_TARGETS

    {
      "schema_version" => 5,
      "repo_root" => @repo_root,
      "overlay" => overlay_overview(overlay),
      "base_policy_count" => core_policies.length,
      "effective_policy_count" => effective_policies(overlay).length,
      "current_repo_target" => read_json_if_exists(File.join(@repo_root, MARKER_FILENAME)),
      "targets" => targets.map { |item| inspect_target_payload(item, overlay: overlay) }
    }
  end

  def inspect_target_payload(target, overlay:)
    default_profile_name, default_profile = default_profile_for_target(target)
    generated_manifest = read_json_if_exists(File.join(default_output_root(target), ".vibe", "manifest.json"))
    preview_manifest = build_manifest(
      target: target,
      profile_name: default_profile_name,
      profile: default_profile,
      output_root: default_output_root(target),
      overlay: overlay
    )

    {
      "target" => target,
      "default_profile" => default_profile_name,
      "profile_maturity" => default_profile["maturity"],
      "profile_notes" => preview_manifest["profile_notes"],
      "resolved_profile_mapping" => preview_manifest["profile_mapping"],
      "overlay" => preview_manifest["overlay"],
      "native_config_overlay" => preview_manifest["native_config_overlay"],
      "generated_output" => File.expand_path(default_output_root(target)),
      "generated_manifest_present" => !generated_manifest.nil?,
      "generated_manifest" => generated_manifest
    }
  end
end
if __FILE__ == $PROGRAM_NAME
  begin
    repo_root = File.expand_path("..", __dir__)
    VibeCLI.new(repo_root).run(ARGV)
  rescue Vibe::PathSafetyError, Vibe::SecurityError, Vibe::ValidationError, Vibe::ConfigurationError => e
    warn "Error: #{e.message}"
    exit 1
  rescue Vibe::Error => e
    warn "Vibe error: #{e.message}"
    exit 1
  end
end
